generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum MembershipStatus {
  contributor
  regular
}

enum EventTag {
  movie
  chuanmen
  holiday
  hiking
  outdoor
  small_group
  other
}

enum EventPhase {
  invite
  open
  closed
  ended
  cancelled
}

enum UserStatus {
  applicant
  announced
  approved
  rejected
  banned
}

enum EventStatus {
  scheduled
  completed
  cancelled
}

enum SignupMode {
  direct
  application
}

enum EventSignupStatus {
  invited
  offered
  accepted
  waitlist
  pending
  declined
  rejected
  cancelled
}

enum RecommendationCategory {
  movie
  book
  recipe
  music
  place
  external_event
}

enum RecommendationStatus {
  candidate
  featured
  archived
}

enum MovieStatus {
  candidate
  screened
}

enum ProposalStatus {
  discussing
  scheduled
  completed
  cancelled
}

enum PostcardVisibility {
  public
  private
}

// v2.1: Seed moved to V2, enums kept for migration compatibility
enum SeedStatus {
  active
  paused
  completed
  cancelled
}

enum SeedCollaboratorStatus {
  invited
  active
  rejected
  left
}

enum AboutContentType {
  principle
  host_guide
  letter
  about
}

enum WeeklyLotteryStatus {
  pending
  accepted
  completed
  skipped
}

// v2.1: AgentPush enums removed (kept for migration reference)
// enum AgentPushGoal { A B C D E F G }
// enum AgentPushChannel { email web feed }

enum EmailState {
  active
  weekly
  stopped
  unsubscribed
}

enum MediaAssetStatus {
  pending
  uploaded
}

enum InteractionEntityType {
  event
  movie
  proposal
  postcard
  // v2.1: seed moved to V2, discussion_reply removed (use unified comment)
  seed
  seed_update
  discussion
  comment
  announcement
  user
  recommendation
}

model User {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  avatar               String              @default("")
  bio                  String              @default("")
  role                 String              @default("member")
  city                 String              @default("")
  state                String              @default("")
  zipCode              String              @default("")
  hostCount            Int                 @default(0)
  participationCount   Int                 @default(0)
  proposalCount        Int                 @default(0)
  postcardSentCount    Int                 @default(0)
  postcardReceivedCount Int                @default(0)
  membershipStatus     MembershipStatus    @default(regular)  // v2.1 new fields
  userStatus           UserStatus          @default(applicant)
  googleId             String?             @unique
  wechatId             String              @default("")
  hideEmail            Boolean             @default(false)
  hideActivity         Boolean             @default(false)
  hideStats            Boolean             @default(false)
  hiddenTitleIds       String[]            @default([])
  location             String              @default("")
  selfAsFriend         String              @default("")
  idealFriend          String              @default("")
  participationPlan    String              @default("")
  coverImageUrl        String              @default("")
  referralSource       String              @default("")
  defaultHouseRules    String              @default("")
  homeAddress          String              @default("")
  subscribeNewsletter  Boolean             @default(true)
  postcardCredits      Int                 @default(4)
  hostCandidate        Boolean             @default(false)
  consecutiveEvents    Int                 @default(0)
  lastEventAt          DateTime?
  birthday             DateTime?
  hideBirthday         Boolean             @default(false)
  announcedAt          DateTime?
  announcedEndAt       DateTime?
  approvedAt           DateTime?
  lastActiveAt         DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  operatorRoles        UserOperatorRole[]
  socialTitles         UserSocialTitle[]
  preferences          UserPreference?
  hostedEvents         Event[]             @relation("EventHost")
  coHostedEvents       EventCoHost[]
  excludedEvents       EventVisibilityExclusion[]
  recordedEvents       Event[]             @relation("EventRecorder")
  eventSignups         EventSignup[]
  recommendedMovies    Movie[]             @relation("MovieRecommender")
  movieVotes           MovieVote[]
  authoredProposals    Proposal[]          @relation("ProposalAuthor")
  organizedProposals   Proposal[]          @relation("ProposalOrganizer")
  proposalVotes        ProposalVote[]
  postcardsSent        Postcard[]          @relation("PostcardFrom")
  postcardsReceived    Postcard[]          @relation("PostcardTo")
  seeds                Seed[]              @relation("SeedAuthor")
  seedCollaborations   SeedCollaborator[]
  seedUpdates          SeedUpdate[]        @relation("SeedUpdateAuthor")
  discussions          Discussion[]
  // v2.1: DiscussionReply removed, use unified Comment model
  likes                Like[]
  comments             Comment[]
  weeklyLotteries      WeeklyLottery[]
  experimentPairingsA  ExperimentPairing[] @relation("PairingA")
  experimentPairingsB  ExperimentPairing[] @relation("PairingB")
  mediaAssets          MediaAsset[]
  recommendations      Recommendation[]
  recommendationVotes  RecommendationVote[]
  linkedEventRecs      EventRecommendation[]
  postcardPurchases    PostcardPurchase[]
  announcements        Announcement[]       @relation("AnnouncementAuthor")
  emailLogs            EmailLog[]
  newsletters          Newsletter[]         @relation("NewsletterAuthor")
  emailQueueItems      EmailQueue[]         @relation("EmailQueueUser")
  emailUnsubscribes    EmailUnsubscribe[]   @relation("EmailUnsubUser")
  claimedTasks         EventTask[]
  feedbacks            Feedback[]
  dailyActiveLogs      DailyActiveLog[]

  // Weekend status (legacy, replaced by ActivitySignal)
  weekendStatus        String?
  weekendNote          String?
  weekendUpdatedAt     DateTime?

  activitySignals      ActivitySignal[]
}

model UserOperatorRole {
  id        String   @id @default(cuid())
  userId    String
  value     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, value])
}

model UserSocialTitle {
  id        String   @id @default(cuid())
  userId    String
  value     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, value])
}

model UserPreference {
  id              String     @id @default(cuid())
  userId          String     @unique
  emailState      EmailState @default(active)
  unopenedStreak  Int        @default(0)
  lastDailySentAt DateTime?
  notifyEvents    Boolean    @default(true)
  notifyCards     Boolean    @default(true)
  notifyOps       Boolean    @default(true)
  notifyAnnounce  Boolean    @default(true)
  notifReadAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mutedGoals      UserMutedGoal[]
}

model UserMutedGoal {
  id               String         @id @default(cuid())
  userPreferenceId String
  value            String

  userPreference   UserPreference @relation(fields: [userPreferenceId], references: [id], onDelete: Cascade)

  @@unique([userPreferenceId, value])
}

model Event {
  id                     String                    @id @default(cuid())
  title                  String
  hostId                 String
  proposalId             String?
  titleImageUrl          String                    @default("")
  description            String                    @default("")
  houseRules             String                    @default("")
  city                   String                    @default("")
  state                  String                    @default("")
  zipCode                String                    @default("")
  address                String                    @default("")
  location               String                    @default("")
  startsAt               DateTime
  endsAt                 DateTime?
  capacity               Int                       @default(10)
  tags                   EventTag[]                @default([other])
  phase                  EventPhase                @default(open)
  publishAt              DateTime?
  status                 EventStatus               @default(scheduled)
  recap                  String                    @default("")
  recapPhotoUrls         String[]
  recorderUserId         String?
  waitlistEnabled        Boolean                   @default(true)
  isWeeklyLotteryEvent   Boolean                   @default(false)
  pinned                 Boolean                   @default(false)
  // v2.1 new fields
  inviteDeadline         DateTime?
  // v2.2 unified recommendation selection
  recSelectionMode       String                    @default("nominate")
  recCategories          String[]                  @default([])
  isHomeEvent            Boolean                   @default(false)
  locationPrivate        Boolean                   @default(false)
  isPrivate              Boolean                   @default(false)
  signupMode             SignupMode                @default(application)
  foodOption             String                    @default("")
  restaurantLocation     String                    @default("")
  creditsAwarded         Boolean                   @default(false)
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  host                   User                      @relation("EventHost", fields: [hostId], references: [id], onDelete: Restrict)
  proposal               Proposal?                 @relation("EventProposal", fields: [proposalId], references: [id], onDelete: SetNull)
  recorder               User?                     @relation("EventRecorder", fields: [recorderUserId], references: [id], onDelete: SetNull)
  coHosts                EventCoHost[]
  visibilityExclusions   EventVisibilityExclusion[]
  signups                EventSignup[]
  postcards              Postcard[]
  weeklyLotteryEntries   WeeklyLottery[]
  screenedMovies         MovieScreening[]
  recommendations        EventRecommendation[]
  tasks                  EventTask[]

  @@index([startsAt, phase])
  @@index([startsAt(sort: Desc), status])
}

model EventCoHost {
  id        String   @id @default(cuid())
  eventId   String
  userId    String

  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventVisibilityExclusion {
  id        String   @id @default(cuid())
  eventId   String
  userId    String

  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventSignup {
  id                   String            @id @default(cuid())
  eventId              String
  userId               String
  invitedById          String?
  status               EventSignupStatus @default(invited)
  invitedAt            DateTime?
  offeredAt            DateTime?
  respondedAt          DateTime?
  participated         Boolean           @default(false)
  checkedInAt          DateTime?
  note                 String            @default("")
  intendedTaskId       String?
  lastReminderSentAt   DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  event                Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, status, createdAt])
  @@index([userId, invitedAt])
}

model Recommendation {
  id          String                 @id @default(cuid())
  category    RecommendationCategory
  title       String
  description String                 @default("")
  authorId    String
  sourceUrl   String                 @default("")
  coverUrl    String                 @default("")
  voteCount   Int                    @default(0)
  status      RecommendationStatus   @default(candidate)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  author          User                   @relation(fields: [authorId], references: [id], onDelete: Restrict)
  tags            RecommendationTag[]
  votes           RecommendationVote[]
  events          EventRecommendation[]
  dailyQuestionId String?
  dailyQuestion   DailyQuestion?         @relation(fields: [dailyQuestionId], references: [id])

  @@index([category, createdAt(sort: Desc)])
  @@index([title])
}

model RecommendationVote {
  id               String         @id @default(cuid())
  recommendationId String
  userId           String
  createdAt        DateTime       @default(now())

  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, userId])
}

model RecommendationTag {
  id               String          @id @default(cuid())
  recommendationId String
  value            String

  recommendation   Recommendation  @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, value])
}

model EventRecommendation {
  id               String          @id @default(cuid())
  eventId          String
  recommendationId String
  linkedById       String?
  isSelected       Boolean         @default(false)
  isNomination     Boolean         @default(false)
  createdAt        DateTime        @default(now())

  event            Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recommendation   Recommendation  @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  linkedBy         User?           @relation(fields: [linkedById], references: [id], onDelete: SetNull)

  @@unique([eventId, recommendationId])
  @@index([eventId])
  @@index([recommendationId])
}

model Movie {
  id            String       @id @default(cuid())
  title         String
  year          Int?
  director      String       @default("")
  poster        String       @default("")
  doubanUrl     String       @default("")
  doubanRating  Float?
  synopsis      String       @default("")
  recommendedById String
  status        MovieStatus  @default(candidate)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  recommendedBy User         @relation("MovieRecommender", fields: [recommendedById], references: [id], onDelete: Restrict)
  screenedEvents MovieScreening[]
  votes         MovieVote[]
  @@index([status, createdAt(sort: Desc)])
  @@index([title])
}

model MovieScreening {
  id       String   @id @default(cuid())
  movieId  String
  eventId  String

  movie    Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([movieId, eventId])
}

model MovieVote {
  id        String   @id @default(cuid())
  movieId   String
  userId    String
  createdAt DateTime @default(now())

  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([movieId, userId])
}

model Proposal {
  id            String        @id @default(cuid())
  title         String
  description   String        @default("")
  authorId      String
  organizerId   String?
  status        ProposalStatus @default(discussing)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  author          User          @relation("ProposalAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  organizer       User?         @relation("ProposalOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  events          Event[]       @relation("EventProposal")
  votes           ProposalVote[]
  dailyQuestionId String?
  dailyQuestion   DailyQuestion? @relation(fields: [dailyQuestionId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([title])
}

model ProposalVote {
  id          String   @id @default(cuid())
  proposalId  String
  userId      String
  createdAt   DateTime @default(now())

  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
}

model Postcard {
  id         String            @id @default(cuid())
  fromId     String
  toId       String
  eventId    String?
  eventCtx   String            @default("")
  message    String
  visibility PostcardVisibility @default(private)
  photoUrl   String            @default("")
  createdAt  DateTime          @default(now())

  from       User              @relation("PostcardFrom", fields: [fromId], references: [id], onDelete: Restrict)
  to         User              @relation("PostcardTo", fields: [toId], references: [id], onDelete: Restrict)
  event      Event?            @relation(fields: [eventId], references: [id], onDelete: SetNull)
  tags       PostcardTag[]

  @@index([toId, createdAt(sort: Desc)])
  @@index([fromId, createdAt(sort: Desc)])
}

model PostcardTag {
  id         String    @id @default(cuid())
  postcardId String
  value      String

  postcard   Postcard  @relation(fields: [postcardId], references: [id], onDelete: Cascade)

  @@unique([postcardId, value])
}

model Seed {
  id          String      @id @default(cuid())
  title       String
  description String      @default("")
  authorId    String
  status      SeedStatus  @default(active)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  author      User        @relation("SeedAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  collaborators SeedCollaborator[]
  updates     SeedUpdate[]

  @@index([status, updatedAt(sort: Desc)])
  @@index([title])
}

model SeedCollaborator {
  id         String                 @id @default(cuid())
  seedId     String
  userId     String
  roleLabel  String                 @default("")
  status     SeedCollaboratorStatus @default(active)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  seed       Seed                   @relation(fields: [seedId], references: [id], onDelete: Cascade)
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seedId, userId])
}

model SeedUpdate {
  id         String      @id @default(cuid())
  seedId     String
  authorId   String
  content    String
  createdAt  DateTime    @default(now())

  seed       Seed        @relation(fields: [seedId], references: [id], onDelete: Cascade)
  author     User        @relation("SeedUpdateAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  media      SeedUpdateMedia[]

  @@index([seedId, createdAt(sort: Desc)])
}

model SeedUpdateMedia {
  id          String      @id @default(cuid())
  seedUpdateId String
  url         String

  seedUpdate  SeedUpdate  @relation(fields: [seedUpdateId], references: [id], onDelete: Cascade)
}

model Discussion {
  id         String      @id @default(cuid())
  authorId   String
  title      String
  body       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  author     User        @relation(fields: [authorId], references: [id], onDelete: Restrict)
  // v2.1: replies now use unified Comment model (entityType=discussion)

  @@index([createdAt(sort: Desc)])
}

// v2.1: DiscussionReply removed — use Comment model with entityType=discussion instead
// model DiscussionReply { ... }

model Like {
  id         String                 @id @default(cuid())
  entityType InteractionEntityType
  entityId   String
  userId     String
  createdAt  DateTime               @default(now())

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, userId])
  @@index([entityType, entityId, createdAt(sort: Desc)])
}

model Comment {
  id               String                 @id @default(cuid())
  entityType       InteractionEntityType
  entityId         String
  authorId         String
  content          String
  parentCommentId  String?
  mentionedUserIds String[]               @default([])
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  author          User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   Comment?               @relation("CommentTree", fields: [parentCommentId], references: [id], onDelete: SetNull)
  childComments   Comment[]              @relation("CommentTree")

  @@index([entityType, entityId, createdAt])
}

model AboutContent {
  id         String           @id @default(cuid())
  type       AboutContentType
  title      String
  content    String
  published  Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([type, updatedAt(sort: Desc)])
}

model WeeklyLottery {
  id            String              @id @default(cuid())
  weekKey       String              @unique
  weekNumber    Int
  drawnMemberId String
  status        WeeklyLotteryStatus @default(pending)
  eventId       String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  drawnMember   User                @relation(fields: [drawnMemberId], references: [id], onDelete: Restrict)
  event         Event?              @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
}

model ExperimentPairing {
  id           String   @id @default(cuid())
  experimentId String
  userAId      String
  userBId      String
  metAt        DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userA        User     @relation("PairingA", fields: [userAId], references: [id], onDelete: Restrict)
  userB        User     @relation("PairingB", fields: [userBId], references: [id], onDelete: Restrict)

  @@unique([experimentId, userAId, userBId])
}

// v2.1: AgentPush removed, replaced by email system (managed outside Prisma for now)
// Kept as comment for migration reference:
// model AgentPush { ... }

model Announcement {
  id         String   @id @default(cuid())
  authorId   String
  title      String
  body       String
  type       String   @default("announcement")
  pinned     Boolean  @default(false)
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author     User     @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([createdAt(sort: Desc)])
}

model PostcardPurchase {
  id        String   @id @default(cuid())
  userId    String
  quantity  Int
  amountUsd Int
  stripeId  String   @default("")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt(sort: Desc)])
}

model MediaAsset {
  id          String           @id @default(cuid())
  key         String           @unique
  ownerId     String?
  contentType String
  fileSize    Int              @default(0)
  status      MediaAssetStatus @default(pending)
  url         String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  owner       User?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
}

model EmailRule {
  id           String   @id
  enabled      Boolean  @default(true)
  displayOrder Int      @default(0)
  cooldownDays Int      @default(0)
  config       Json     @default("{}")
  updatedAt    DateTime @updatedAt
}

model EmailTemplate {
  id         String   @id @default(cuid())
  ruleId     String
  variantKey String   @default("default")
  subject    String
  body       String
  isActive   Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  @@unique([ruleId, variantKey])
}

model EmailLog {
  id        String    @id @default(cuid())
  userId    String
  ruleId    String
  refId     String?
  messageId String?
  sentAt    DateTime  @default(now())
  openedAt  DateTime?
  clickedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ruleId, sentAt(sort: Desc)])
  @@index([userId, sentAt(sort: Desc)])
}

model LoginCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, code])
}

model DailyActiveLog {
  id     String   @id @default(cuid())
  userId String
  date   String   // "YYYY-MM-DD"
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model TitleRule {
  id          String   @id @default(cuid())
  emoji       String
  name        String
  description String   @default("")
  stampEmoji  String
  threshold   Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model TaskPreset {
  id        String   @id @default(cuid())
  tag       String   @unique
  roles     Json     @default("[]")  // Array of { role: string, description: string }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventTask {
  id          String   @id @default(cuid())
  eventId     String
  role        String
  description String   @default("")
  claimedById String?
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  claimedBy User? @relation(fields: [claimedById], references: [id], onDelete: SetNull)

  @@index([eventId])
}

// ─── Newsletter ───────────────────────────────────────────
model Newsletter {
  id             String    @id @default(cuid())
  subject        String
  body           String    @default("")
  status         String    @default("draft") // draft, scheduled, sent
  recipientCount Int       @default(0)
  openRate       Float     @default(0)
  clickRate      Float     @default(0)
  recipientGroup String    @default("全部成员")
  recipientIds   String[]  // individual recipient user IDs (when not group)
  sentAt         DateTime?
  authorId       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  author         User      @relation("NewsletterAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([status, createdAt(sort: Desc)])
}

// ─── Site Config (key-value store) ────────────────────────
model SiteConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ─── Email Queue ──────────────────────────────────────────
model EmailQueue {
  id          String   @id @default(cuid())
  userId      String
  ruleId      String
  scheduledAt DateTime
  status      String   @default("queued") // queued, paused, sent, failed, cancelled
  payload     Json     @default("{}")
  createdAt   DateTime @default(now())

  user        User     @relation("EmailQueueUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([userId])
}

// ─── Email Bounce ─────────────────────────────────────────
model EmailBounce {
  id         String   @id @default(cuid())
  email      String
  ruleId     String
  type       String   // hard_bounce, soft_bounce, complaint
  reason     String   @default("")
  occurredAt DateTime @default(now())

  @@index([email])
  @@index([occurredAt(sort: Desc)])
}

// ─── Email Unsubscribe ────────────────────────────────────
model EmailUnsubscribe {
  id             String   @id @default(cuid())
  userId         String?
  email          String
  reason         String   @default("")
  comment        String   @default("")
  unsubscribedAt DateTime @default(now())

  user           User?    @relation("EmailUnsubUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([unsubscribedAt(sort: Desc)])
}

// ─── Email Suppression ───────────────────────────────────
model EmailSuppression {
  id      String   @id @default(cuid())
  email   String   @unique
  reason  String   @default("")
  source  String   @default("system") // system, admin
  addedAt DateTime @default(now())
}

// ─── Daily Question ─────────────────────────────────────
model DailyQuestion {
  id               String           @id @default(cuid())
  text             String
  targetType       String           // 'recommendation' | 'proposal' | 'comment'
  targetCategory   String?          // recommendation category: music/place/movie/book/recipe/external_event
  targetEntityType String?          // comment entityType: event/movie/recommendation
  date             DateTime?        @unique @db.Date
  createdAt        DateTime         @default(now())

  recommendations  Recommendation[]
  proposals        Proposal[]
}

// ─── Activity Signal ─────────────────────────────────────
model ActivitySignal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tag       String   // "hiking", "movie", "eat", "deeptalk", etc.
  weekKey   String   // ISO week: "2026-W12"
  createdAt DateTime @default(now())

  @@unique([userId, tag, weekKey])
  @@index([weekKey])
  @@index([userId])
}

// ─── User Feedback ───────────────────────────────────────
model Feedback {
  id         String   @id @default(cuid())
  authorId   String?
  name       String
  email      String?
  category   String   // 'feature' | 'bug' | 'activity' | 'other'
  message    String
  page       String?
  status     String   @default("pending") // 'pending' | 'noted' | 'replied' | 'done' | 'wontfix'
  adminNote  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt(sort: Desc)])
}
