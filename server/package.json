{
  "name": "chuanmen-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src_v2/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "db:local": "ln -sf .env.development .env && echo '✅ Switched to LOCAL (Docker Postgres)'",
    "db:dev": "ln -sf .env.dev .env && echo '✅ Switched to DEV (Render chuanmener-dev)'",
    "db:prod": "ln -sf .env.production .env && echo '⚠️  Switched to PROD (RDS chuanmener-prod)'",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:setup": "npm run docker:up && sleep 3 && npm run db:push && npm run db:seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "agent:tick": "tsx src_v2/workers/agentTick.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "system:test:up": "./system-test/up.sh",
    "system:test:down": "./system-test/down.sh",
    "system:test:logs": "./system-test/logs.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/s3-request-presigner": "^3.883.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^8.2.0",
    "@prisma/client": "^6.16.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.0",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.16.3",
    "resend": "^6.9.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "prisma": "^6.16.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
