{
  "framework": "vite",
  "installCommand": "npm install && cd server && npm install && npx prisma generate",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "server/node_modules/.prisma/**"
    }
  }
}
