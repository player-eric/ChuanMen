echo "🔍 Linting frontend..."
npx eslint src/ --quiet || exit 1

echo "🔍 Linting backend..."
cd server && npx eslint src_v2/ --max-warnings 0 || exit 1
cd ..

echo "🔍 Running structural tests..."
cd server && npx vitest run tests/structural/ --reporter=dot 2>&1 | tail -5 || exit 1
cd ..

echo "🔍 Type-checking frontend..."
npx tsc --noEmit || exit 1

echo "🔍 Type-checking backend..."
cd server && npx tsc --noEmit || exit 1
cd ..

echo "🔍 Checking backward compatibility (Prisma validate)..."
cd server && npx prisma validate || exit 1
cd ..

echo "🔍 Checking schema changes have migrations..."
if git diff --cached --name-only | grep -q "server/prisma/schema.prisma"; then
  if ! git diff --cached --name-only | grep -q "server/prisma/migrations/"; then
    echo "❌ schema.prisma changed but no migration file added!"
    echo "   Run: cd server && npx prisma migrate dev --name <name>"
    echo "   Or create a manual migration in server/prisma/migrations/"
    exit 1
  fi
fi

echo "🏗️ Building..."
npm run build || exit 1

echo "✅ Pre-commit checks passed"
